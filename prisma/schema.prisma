generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  PARTNER_MANAGER
  PARTNER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  PDF
  QUIZ
  EXTERNAL_LINK
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LeadStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  MORE_INFORMATION_REQUIRED
  DOCUMENTS_RECEIVED
  APPROVED
  DECLINED
  FUNDED
  COMMISSION_PENDING
  COMMISSION_PAID
}

enum LeadRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum LeadNoteType {
  INTERNAL
  PARTNER
}

enum NotificationType {
  SYSTEM
  TRAINING
  LEAD_UPDATE
  RESOURCE
  COMMUNITY
  ANNOUNCEMENT
}

enum CommunitySpaceVisibility {
  PUBLIC
  PRIVATE
  ADMIN_ONLY
}

enum CommunityPostType {
  ANNOUNCEMENT
  QUESTION
  DISCUSSION
  WIN
  RESOURCE_SHARE
}

enum CommunityReactionType {
  LIKE
  CELEBRATE
  HELPFUL
  IDEA
}

enum ReportedContentType {
  POST
  COMMENT
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum ResourceKind {
  FILE
  EXTERNAL_LINK
}

enum ResourceStatus {
  ACTIVE
  ARCHIVED
}

model Organization {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  slug         String        @unique
  logoUrl      String?
  primaryColor String?
  tagline      String?
  website      String?
  contactEmail String?
  supportPhone String?
  users        User[]
  courses      Course[]
  resources    Resource[]
  resourceDownloads ResourceDownload[]
  leads        Lead[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  notificationSubscriptions NotificationSubscription[]
  branding OrganizationBranding?
  integrations Integration[]
  userPreferences UserPreference[]
  communitySpaces CommunitySpace[]
  communityPosts CommunityPost[]
  communityComments CommunityComment[]
  communityReactions CommunityReaction[]
  savedPosts SavedPost[]
  reportedContent ReportedContent[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id                    String           @id @default(uuid()) @db.Uuid
  organizationId        String           @db.Uuid
  email                 String
  name                  String
  avatarUrl             String?
  phone                 String?
  jobTitle              String?
  bio                   String?
  role                  Role
  status                UserStatus
  lastLoginAt           DateTime?
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lessonProgressRecords LessonProgress[]
  uploadedResources     Resource[]       @relation("ResourceUploadedBy")
  resourceDownloads     ResourceDownload[]
  submittedLeads        Lead[]           @relation("LeadSubmittedBy")
  managedLeads          Lead[]           @relation("LeadAssignedManager")
  leadNotes             LeadNote[]       @relation("LeadNoteAuthor")
  uploadedLeadDocuments LeadDocument[]   @relation("LeadDocumentUploadedBy")
  notifications         Notification[]
  userPreference        UserPreference?
  notificationPreference NotificationPreference?
  notificationSubscriptions NotificationSubscription[]
  communitySpaces      CommunitySpace[] @relation("CommunitySpaceCreatedBy")
  communityPosts       CommunityPost[] @relation("CommunityPostAuthor")
  communityComments    CommunityComment[] @relation("CommunityCommentAuthor")
  communityReactions   CommunityReaction[]
  savedPosts           SavedPost[]
  reportedContent      ReportedContent[] @relation("ReportedContentReporter")
  moderatedReports     ReportedContent[] @relation("ReportedContentModerator")
  activityLogs          ActivityLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([role])
  @@index([status])
}

model Course {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  title          String
  slug           String
  description    String?
  thumbnailUrl   String?
  status         CourseStatus
  sortOrder      Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modules        Module[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
}

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @db.Uuid
  title       String
  description String?
  sortOrder   Int      @default(0)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
}

model Lesson {
  id              String               @id @default(uuid()) @db.Uuid
  moduleId        String               @db.Uuid
  title           String
  slug            String
  content         String?
  videoUrl        String?
  durationMinutes Int?
  lessonType      LessonType
  sortOrder       Int                  @default(0)
  isRequired      Boolean              @default(true)
  module          Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progressRecords LessonProgress[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@index([lessonType])
}

model LessonProgress {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @db.Uuid
  lessonId    String               @db.Uuid
  status      LessonProgressStatus
  completedAt DateTime?
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([status])
}

model Resource {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  title          String
  description    String?
  fileUrl        String
  fileType       String
  category       String
  version        String?
  originalFileName String?
  resourceKind   ResourceKind @default(FILE)
  status         ResourceStatus @default(ACTIVE)
  uploadedById   String?      @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User?        @relation("ResourceUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  downloads      ResourceDownload[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([uploadedById])
  @@index([category])
  @@index([status])
  @@index([resourceKind])
}

model ResourceDownload {
  id             String       @id @default(uuid()) @db.Uuid
  resourceId     String       @db.Uuid
  userId         String?      @db.Uuid
  organizationId String       @db.Uuid
  resource       Resource     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  downloadedAt   DateTime     @default(now())

  @@index([resourceId])
  @@index([userId])
  @@index([organizationId])
}

model Lead {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  submittedById   String?      @db.Uuid
  assignedManagerId String?    @db.Uuid
  clientName      String
  clientEmail     String
  clientPhone     String?
  businessName    String?
  industry        String?
  website         String?
  businessAgeYears Int?
  requestedAmount Decimal?     @db.Decimal(12, 2)
  fundingPurpose  String?
  revenue         String?
  employeeCount   Int?
  riskLevel       LeadRiskLevel @default(MEDIUM)
  notes           String?
  status          LeadStatus
  submittedAt     DateTime?
  lastActivityAt  DateTime     @default(now())
  isArchived      Boolean      @default(false)
  archivedAt      DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy     User?        @relation("LeadSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  assignedManager User?        @relation("LeadAssignedManager", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  leadNotes       LeadNote[]
  documents       LeadDocument[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([submittedById])
  @@index([assignedManagerId])
  @@index([status])
  @@index([isArchived])
  @@index([clientEmail])
}

model LeadNote {
  id         String   @id @default(uuid()) @db.Uuid
  leadId     String   @db.Uuid
  authorId   String?  @db.Uuid
  parentNoteId String? @db.Uuid
  note       String
  noteType   LeadNoteType @default(PARTNER)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author     User?    @relation("LeadNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  parentNote LeadNote? @relation("LeadNoteReplies", fields: [parentNoteId], references: [id], onDelete: Cascade)
  replies    LeadNote[] @relation("LeadNoteReplies")
  documents  LeadDocument[]
  createdAt  DateTime @default(now())

  @@index([leadId])
  @@index([authorId])
  @@index([parentNoteId])
}

model LeadDocument {
  id           String   @id @default(uuid()) @db.Uuid
  leadId       String   @db.Uuid
  noteId       String?  @db.Uuid
  fileName     String
  originalFileName String?
  fileUrl      String
  fileType     String
  fileSizeBytes Int?
  uploadedById String?  @db.Uuid
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation("LeadDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  note         LeadNote? @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([noteId])
  @@index([uploadedById])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  userId    String           @db.Uuid
  title     String
  message   String
  type      NotificationType
  linkUrl   String?
  entityType String?
  entityId  String?          @db.Uuid
  readAt    DateTime?
  deletedAt DateTime?
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([deletedAt])
}

model NotificationPreference {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @unique @db.Uuid
  training       Boolean      @default(true)
  leadUpdates    Boolean      @default(true)
  announcements  Boolean      @default(true)
  browserPush    Boolean      @default(false)
  email          Boolean      @default(false)
  quietHours     String?
  digestFrequency String      @default("IMMEDIATE")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model NotificationSubscription {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @db.Uuid
  endpoint       String       @unique
  p256dh         String
  auth           String
  userAgent      String?
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([isActive])
}

model UserPreference {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @unique @db.Uuid
  language       String       @default("en")
  timezone       String       @default("UTC")
  dateFormat     String       @default("MMM d, yyyy")
  theme          String       @default("system")
  visibility     String       @default("organization")
  activityStatus Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model OrganizationBranding {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid
  appName        String       @default("Pohuntoon")
  primaryColor   String       @default("#1E4E9A")
  secondaryColor String       @default("#29B7E5")
  accentColor    String       @default("#6E4BD8")
  lightLogoUrl   String?
  darkLogoUrl    String?
  faviconUrl     String?
  splashImageUrl String?
  loginBranding  Json?
  emailBranding  Json?
  customDomain   String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Integration {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  provider       String
  name           String
  status         String       @default("NOT_CONNECTED")
  isEnabled      Boolean      @default(false)
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
}

model CommunitySpace {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @db.Uuid
  name           String
  slug           String
  description    String?
  icon           String                   @default("MessageCircle")
  color          String                   @default("#6E4BD8")
  visibility     CommunitySpaceVisibility @default(PUBLIC)
  memberCount    Int                      @default(0)
  postCount      Int                      @default(0)
  createdById    String?                  @db.Uuid
  isArchived     Boolean                  @default(false)
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?                    @relation("CommunitySpaceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  posts          CommunityPost[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([visibility])
  @@index([createdById])
}

model CommunityPost {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  spaceId        String            @db.Uuid
  authorId       String?           @db.Uuid
  type           CommunityPostType
  title          String
  body           String
  attachments    Json?
  pollOptions    Json?
  isPinned       Boolean           @default(false)
  isHidden       Boolean           @default(false)
  deletedAt      DateTime?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space          CommunitySpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author         User?             @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  comments       CommunityComment[]
  reactions      CommunityReaction[]
  savedBy        SavedPost[]
  reports        ReportedContent[] @relation("ReportedPost")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([spaceId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isHidden])
  @@index([deletedAt])
}

model CommunityComment {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  postId         String            @db.Uuid
  authorId       String?           @db.Uuid
  parentId       String?           @db.Uuid
  body           String
  isHidden       Boolean           @default(false)
  deletedAt      DateTime?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  post           CommunityPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author         User?             @relation("CommunityCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  parent         CommunityComment? @relation("CommunityCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        CommunityComment[] @relation("CommunityCommentReplies")
  reactions      CommunityReaction[]
  reports        ReportedContent[] @relation("ReportedComment")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

model CommunityReaction {
  id             String                @id @default(uuid()) @db.Uuid
  organizationId String                @db.Uuid
  userId         String                @db.Uuid
  postId         String?               @db.Uuid
  commentId      String?               @db.Uuid
  type           CommunityReactionType
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           CommunityPost?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment        CommunityComment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now())

  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([organizationId])
  @@index([postId])
  @@index([commentId])
  @@index([userId])
}

model SavedPost {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  userId         String        @db.Uuid
  postId         String        @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([userId, postId])
  @@index([organizationId])
  @@index([postId])
  @@index([userId])
}

model ReportedContent {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  reporterId     String?             @db.Uuid
  moderatorId    String?             @db.Uuid
  postId         String?             @db.Uuid
  commentId      String?             @db.Uuid
  contentType    ReportedContentType
  reason         String
  status         ReportStatus        @default(OPEN)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reporter       User?               @relation("ReportedContentReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  moderator      User?               @relation("ReportedContentModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  post           CommunityPost?      @relation("ReportedPost", fields: [postId], references: [id], onDelete: Cascade)
  comment        CommunityComment?   @relation("ReportedComment", fields: [commentId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([reporterId])
  @@index([postId])
  @@index([commentId])
  @@index([status])
  @@index([createdAt])
}

model ActivityLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String?      @db.Uuid
  action         String
  entityType     String
  entityId       String       @db.Uuid
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
}
